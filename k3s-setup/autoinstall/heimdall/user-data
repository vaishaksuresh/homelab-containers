#cloud-config
autoinstall:
  version: 1

  locale: en_US.UTF-8
  keyboard:
    layout: us

  network:
    version: 2
    ethernets:
      # Dell Optiplex interface - check with: ip link show
      # Common names: eno1, enp1s0, enp2s0
      eno1:
        dhcp4: false
        addresses:
          - 10.0.20.160/24
        routes:
          - to: default
            via: 10.0.20.1
        nameservers:
          addresses: [10.0.20.30, 1.1.1.1]

  storage:
    layout:
      name: direct  # Use entire disk, no LVM overhead

  identity:
    hostname: heimdall
    username: vaishak
    # Generate with: python3 -c "import crypt; print(crypt.crypt('yourpassword', crypt.mksalt(crypt.METHOD_SHA512)))"
    password: REPLACE_WITH_HASHED_PASSWORD

  ssh:
    install-server: true
    authorized-keys:
      - REPLACE_WITH_YOUR_PUBLIC_KEY  # cat ~/.ssh/id_rsa.pub

  packages:
    - curl
    - wget
    - git
    - htop
    - nfs-common
    - open-iscsi

  late-commands:
    # Disable swap
    - swapoff -a
    - sed -i '/ swap / s/^\(.*\)$/#\1/g' /target/etc/fstab
    # Timezone
    - curtin in-target --target=/target -- timedatectl set-timezone America/Los_Angeles
    # Kernel modules for K3s
    - echo "overlay" >> /target/etc/modules-load.d/k3s.conf
    - echo "br_netfilter" >> /target/etc/modules-load.d/k3s.conf
    # Sysctl settings for K3s
    - echo "net.bridge.bridge-nf-call-iptables = 1" >> /target/etc/sysctl.d/k3s.conf
    - echo "net.bridge.bridge-nf-call-ip6tables = 1" >> /target/etc/sysctl.d/k3s.conf
    - echo "net.ipv4.ip_forward = 1" >> /target/etc/sysctl.d/k3s.conf

  user-data:
    disable_root: true
